<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" alignment="CENTER" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.Controller">

    <ComboBox fx:id="languageBox" onAction="#changeLanguage"/>

    <Label fx:id="welcomeLabel"/>
    <Label fx:id="instructionLabel"/>

    <Label fx:id="labelQuantity"/>
    <TextField fx:id="quantityField"/>

    <Label fx:id="labelPrice"/>
    <TextField fx:id="priceField"/>
    <Label fx:id="infoLabel"/>

    <Button fx:id="addButton" onAction="#handleAdd"/>
    <Button fx:id="removeButton" onAction="#handleRemove"/>
    <Button fx:id="proceedButton" onAction="#handleProceed"/>
    <Button fx:id="cancelButton" onAction="#handleCancel"/>

    <Label fx:id="totalLabel"/>

</VBox>